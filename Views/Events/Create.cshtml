@model DenzelDev.Models.Event
@{
    ViewData["Title"] = "Create Coordination Event";
}

<div class="py-4">
    <div class="mb-3">
        <a href="/events" class="btn btn-sm btn-outline-secondary">&larr; Back to Dashboard</a>
    </div>

    <div class="card shadow-sm border glass-card">
        <div class="card-header bg-transparent border-bottom border-secondary pb-3">
            <span class="mono-tag">EventList Module</span>
            <h2 class="h3 text-white mb-0 mt-1">Schedule New Coordination Event</h2>
        </div>
        <div class="card-body pt-4 px-0">
            <form method="post" id="create-event-form">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger p-2 small" style="background: rgba(220, 53, 69, 0.2); border: 0; color: #dc3545;">
                        <div asp-validation-summary="All" class="text-danger"></div>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Title" class="form-label text-white">Event Title *</label>
                    <input asp-for="Title" class="form-control minimalist-input" placeholder="e.g. National Developer Hackathon 2026" required>
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="OrganizerName" class="form-label text-white">Organizer Unit / Lead Name *</label>
                        <input asp-for="OrganizerName" class="form-control minimalist-input" placeholder="e.g. Student Council" required>
                        <span asp-validation-for="OrganizerName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Location" class="form-label text-white">Venue Location</label>
                        <input asp-for="Location" class="form-control minimalist-input" placeholder="e.g. Manila Tech Dome (or Online)">
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="EventDate" class="form-label text-white">Target Event Date *</label>
                    <input asp-for="EventDate" type="date" class="form-control minimalist-input" required value="@DateTime.UtcNow.AddDays(14).ToString("yyyy-MM-dd")">
                    <span asp-validation-for="EventDate" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label text-white">Operational Description</label>
                    <textarea asp-for="Description" class="form-control minimalist-input" rows="4" placeholder="Describe the event scope, key metrics, and targeted outcomes..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn-premium-solid border-0" id="btn-save-event">Schedule & Initialize Event &rarr;</button>
                </div>
            </form>
        </div>
    </div>
</div>

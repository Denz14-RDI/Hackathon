@model DenzelDev.Models.Event
@{
    ViewData["Title"] = $"{Model.Title} Sheet";
    
    // Financial sheet LEDGER calculations
    var totalSponsorship = Model.Budgets.Where(b => b.Type == "Sponsorship").Sum(b => b.Amount);
    var totalExpense = Model.Budgets.Where(b => b.Type == "Expense").Sum(b => b.Amount);
    var netBalance = totalSponsorship - totalExpense;

    // Operational Milestone calculations
    var totalTasks = Model.TaskItems.Count;
    var completedTasks = Model.TaskItems.Count(t => t.Status == "Completed");
    var taskProgress = totalTasks > 0 ? (int)((double)completedTasks / totalTasks * 100) : 0;
}

<!-- Notification Alert -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3 border-0 shadow" role="alert" style="background: rgba(40, 167, 69, 0.2); color: #28a745;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3 border-0 shadow" role="alert" style="background: rgba(220, 53, 69, 0.2); color: #dc3545;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="py-4">
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <a href="/events" class="btn btn-sm btn-outline-secondary" id="btn-back-events">&larr; Back to Events Dashboard</a>
        <a href="/events/edit/@Model.Id" class="btn btn-sm btn-outline-light" id="btn-edit-event-details"><i class="bi bi-pencil-square text-accent"></i> Edit Event Info</a>
    </div>

    <!-- Header Stats Banner -->
    <div class="glass-card mb-4 glow-card py-4">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <span class="mono-tag"><i class="bi bi-calendar"></i> Date: @Model.EventDate.ToString("MMMM dd, yyyy") &bull; Venue: @(Model.Location ?? "Online")</span>
                <h1 class="h2 text-white mt-2 mb-2">@Model.Title</h1>
                <p class="small text-muted mb-0">Organized by: <strong>@Model.OrganizerName</strong></p>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted mt-3 mb-0" style="font-size: 0.95rem;">@Model.Description</p>
                }
            </div>

            <!-- Financial Summary Tracker and Task progress bar -->
            <div class="col-lg-5 mt-4 mt-lg-0 border-start border-secondary-subtle ps-lg-4">
                <div class="row mb-3">
                    <div class="col-6">
                        <small class="text-muted d-block">Cashflow Balance</small>
                        <span class="fs-4 font-weight-bold @(netBalance >= 0 ? "text-success" : "text-danger")">
                            @netBalance.ToString("C")
                        </span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Completion Progress</small>
                        <span class="fs-4 text-accent font-weight-bold">@taskProgress%</span>
                    </div>
                </div>
                <div class="progress bg-dark" style="height: 6px; border: 1px solid var(--border-glass);">
                    <div class="progress-bar" role="progressbar" style="width: @taskProgress%; background-color: var(--accent);" aria-valuenow="@taskProgress" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Dual Management Grid -->
    <div class="row g-4">
        <!-- 1. FINANCIAL SHEET LEDGER (LEFT) -->
        <div class="col-xl-6">
            <div class="glass-card h-100 glow-card" id="ledger-pane">
                <h3 class="h4 text-white mb-3 border-bottom pb-2"><i class="bi bi-wallet2 text-accent"></i> Financial Sheet Ledger</h3>
                
                <!-- Budgets List Table -->
                <div class="table-responsive mb-4" style="max-height: 350px; overflow-y: auto;">
                    <table class="table table-hover align-middle table-dark bg-transparent border-0 mb-0" id="table-budgets">
                        <thead>
                            <tr class="text-muted small border-bottom border-secondary">
                                <th>Item Name</th>
                                <th>Allocation Type</th>
                                <th class="text-end">Amount</th>
                                <th style="width: 50px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Budgets.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4 small">No cash transactions logged. Use form below to add.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var b in Model.Budgets)
                                {
                                    <tr class="border-bottom border-secondary-subtle">
                                        <td class="small text-white">@b.ItemName</td>
                                        <td>
                                            <span class="badge @(b.Type == "Sponsorship" ? "bg-success-subtle text-success border border-success" : "bg-danger-subtle text-danger border border-danger") small">
                                                @b.Type
                                            </span>
                                        </td>
                                        <td class="text-end small @(b.Type == "Sponsorship" ? "text-success" : "text-white")">
                                            @b.Amount.ToString("N2")
                                        </td>
                                        <td class="text-end">
                                            <form method="post" action="/events/@Model.Id/budget/delete/@b.Id" onsubmit="return confirm('Remove this budget ledger entry?')" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-link text-danger p-0" id="btn-delete-budget-@b.Id"><i class="bi bi-x-circle-fill"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Add Budget Item Form -->
                <div class="p-3 rounded border border-secondary-subtle" style="background: rgba(11, 15, 25, 0.4);">
                    <h4 class="h6 text-white mb-3">Add Ledger Transaction</h4>
                    <form method="post" action="/events/@Model.Id/budget/add" id="add-budget-form">
                        @Html.AntiForgeryToken()
                        <div class="row g-2">
                            <div class="col-md-5">
                                <input name="ItemName" class="form-control form-control-sm minimalist-input" placeholder="e.g. Snack Catering" required autocomplete="off">
                            </div>
                            <div class="col-md-4">
                                <select name="Type" class="form-select form-select-sm minimalist-input" required>
                                    <option value="Expense">Expense</option>
                                    <option value="Sponsorship">Sponsorship</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <input name="Amount" type="number" step="0.01" min="0.01" class="form-control form-control-sm minimalist-input" placeholder="0.00" required>
                            </div>
                        </div>
                        <div class="text-end mt-2">
                            <button type="submit" class="btn btn-sm btn-premium-solid border-0" id="btn-save-budget-item">Insert Entry &rarr;</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- 2. OPERATIONAL MILESTONES MATRIX (RIGHT) -->
        <div class="col-xl-6">
            <div class="glass-card h-100 glow-card" id="milestones-pane">
                <h3 class="h4 text-white mb-3 border-bottom pb-2"><i class="bi bi-list-check text-accent"></i> Operational Milestones</h3>

                <!-- Tasks List Table -->
                <div class="table-responsive mb-4" style="max-height: 350px; overflow-y: auto;">
                    <table class="table table-hover align-middle table-dark bg-transparent border-0 mb-0" id="table-tasks">
                        <thead>
                            <tr class="text-muted small border-bottom border-secondary">
                                <th>Task Detail</th>
                                <th>Assignee</th>
                                <th>Due Date</th>
                                <th style="width: 140px;">Status</th>
                                <th style="width: 40px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.TaskItems.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4 small">No milestones declared. Use form below to delegate.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var t in Model.TaskItems)
                                {
                                    <tr class="border-bottom border-secondary-subtle">
                                        <td class="small text-white">@t.TaskName</td>
                                        <td class="small text-muted">@(t.AssignedTo ?? "Unassigned")</td>
                                        <td class="small text-muted" style="font-size: 0.8rem;">@t.DueDate.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            <!-- Status Update Form select -->
                                            <form method="post" action="/events/@Model.Id/task/status/@t.Id" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <select name="status" class="form-select form-select-sm minimalist-input border-0 py-0 px-2" onchange="this.form.submit()" style="font-size: 0.8rem; width: 110px;" id="select-task-status-@t.Id">
                                                    <option value="Pending" selected="@(t.Status == "Pending")">Pending</option>
                                                    <option value="In Progress" selected="@(t.Status == "In Progress")">In Progress</option>
                                                    <option value="Completed" selected="@(t.Status == "Completed")">Completed</option>
                                                </select>
                                            </form>
                                        </td>
                                        <td class="text-end">
                                            <form method="post" action="/events/@Model.Id/task/delete/@t.Id" onsubmit="return confirm('Remove this milestone task?')" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-link text-danger p-0" id="btn-delete-task-@t.Id"><i class="bi bi-x-circle-fill"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Add Task Item Form -->
                <div class="p-3 rounded border border-secondary-subtle" style="background: rgba(11, 15, 25, 0.4);">
                    <h4 class="h6 text-white mb-3">Delegate New Milestone</h4>
                    <form method="post" action="/events/@Model.Id/task/add" id="add-task-form">
                        @Html.AntiForgeryToken()
                        <div class="row g-2 mb-2">
                            <div class="col-md-7">
                                <input name="TaskName" class="form-control form-control-sm minimalist-input" placeholder="e.g. Reserve seminar hall" required autocomplete="off">
                            </div>
                            <div class="col-md-5">
                                <input name="AssignedTo" class="form-control form-control-sm minimalist-input" placeholder="Assignee (e.g. John)" autocomplete="off">
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-md-7">
                                <input name="DueDate" type="date" class="form-control form-control-sm minimalist-input" required value="@DateTime.UtcNow.AddDays(7).ToString("yyyy-MM-dd")">
                            </div>
                            <div class="col-md-5 text-end">
                                <button type="submit" class="btn btn-sm btn-premium-solid border-0 w-100" id="btn-save-task-item">Delegate Milestone &rarr;</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@model DenzelDev.Models.Blog
@{
    ViewData["Title"] = $"Edit {Model.Title}";
}

<div class="py-4">
    <div class="mb-3">
        <a href="/admin" class="btn btn-sm btn-outline-secondary">&larr; Back to Control Panel</a>
    </div>

    <div class="card shadow-sm border">
        <div class="card-header bg-dark text-white py-3">
            <h2 class="h5 mb-0">Edit Tech Article: @Model.Title</h2>
        </div>
        <div class="card-body p-4">
            <form method="post" id="edit-blog-form">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedAt" />
                <input type="hidden" asp-for="PublishedDate" />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger p-2 small">
                        <div asp-validation-summary="All" class="text-danger"></div>
                    </div>
                }

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Title" class="form-label">Article Title *</label>
                        <input asp-for="Title" class="form-control" placeholder="e.g. Master Serverless .NET on Vercel" required>
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Slug" class="form-label">URL Slug *</label>
                        <input asp-for="Slug" class="form-control" placeholder="e.g. master-serverless-net" required>
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ReadTimeMinutes" class="form-label">Estimated Read Time (minutes) *</label>
                        <input asp-for="ReadTimeMinutes" type="number" min="1" class="form-control" placeholder="e.g. 5" required>
                        <span asp-validation-for="ReadTimeMinutes" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3 d-flex align-items-center mt-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsPublished" class="form-check-input" type="checkbox" role="switch" id="IsPublishedSwitch">
                            <label class="form-check-label" for="IsPublishedSwitch">Publish Article</label>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="BannerImageUrl" class="form-label">Banner Image URL</label>
                    <input asp-for="BannerImageUrl" class="form-control" placeholder="e.g. https://images.unsplash.com/photo-...">
                    <span asp-validation-for="BannerImageUrl" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ContentMarkdown" class="form-label">Article Markdown Rich Text *</label>
                    <textarea asp-for="ContentMarkdown" class="form-control" rows="12" placeholder="# Enter blog article details here in Markdown..." required></textarea>
                    <span asp-validation-for="ContentMarkdown" class="text-danger small"></span>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-dark" id="btn-update-blog">Update Blog Article</button>
                </div>
            </form>
        </div>
    </div>
</div>

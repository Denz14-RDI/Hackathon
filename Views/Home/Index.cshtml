@model DenzelDev.Models.ContactMessage
@{
    ViewData["Title"] = "Creative Full-Stack Developer";
    var skills = ViewBag.Skills as IEnumerable<DenzelDev.Models.Skill> ?? new List<DenzelDev.Models.Skill>();
}

<!-- Alert Notification banners -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3 border-0 shadow" role="alert" style="background: rgba(40, 167, 69, 0.2); color: #28a745;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3 border-0 shadow" role="alert" style="background: rgba(220, 53, 69, 0.2); color: #dc3545;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- 1. HERO LANDING SECTION -->
<section id="hero-section" class="min-vh-100 d-flex align-items-center py-5">
    <div class="row align-items-center w-100">
        <div class="col-lg-8">
            <span class="mono-tag d-block mb-3 cursor-typing">hello, world. i am</span>
            <h1 class="display-2 font-weight-extrabold mb-3" style="font-family: var(--font-display); line-height: 1.1;">
                Denzel Dev.
            </h1>
            <h2 class="display-5 text-accent mb-4" style="font-family: var(--font-display); font-weight: 600;">
                Crafting robust full-stack systems.
            </h2>
            <p class="fs-5 text-muted mb-5" style="max-width: 600px;">
                I am a highly passionate software engineer specializing in compiling high-performance ASP.NET Core MVC systems, relational database frameworks, and premium glassmorphic UI designs.
            </p>
            <div class="d-flex flex-wrap gap-3">
                <a href="/projects" class="btn-premium-solid text-decoration-none" id="btn-hero-projects">Showcase Projects &rarr;</a>
                <a href="#contact-section" class="btn-premium text-decoration-none" id="btn-hero-contact">Get in Touch</a>
            </div>
        </div>
    </div>
</section>

<!-- 2. ABOUT & EXPERIENCE SECTION -->
<section id="about-section" class="py-5 border-top border-secondary-subtle">
    <div class="row">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <span class="mono-tag">01. identity & story</span>
            <h2 class="h1 mb-4 mt-2">Professional Background</h2>
            <p>
                As a developer, I love building applications that merge powerful, clean-cut backends with highly refined frontend experiences. My background spans building dynamic platforms for academic groups, organizing code hackathons, and developing robust MVC applications.
            </p>
            <p>
                My focus lies in building clean code bases using structured design patterns (MVC, Repository, seedings) that are reliable, easily scalable, and fully optimized.
            </p>
        </div>
        
        <div class="col-lg-6">
            <div class="timeline-wrapper">
                <div class="timeline-line"></div>
                
                <div class="timeline-item" id="experience-item-1">
                    <div class="timeline-node"></div>
                    <div class="timeline-date">2025 - PRESENT</div>
                    <div class="timeline-content">
                        <h4 class="h6 mb-1 text-white">Lead Full-Stack Developer</h4>
                        <p class="small text-accent mb-2">Hackathon Organization Unit</p>
                        <p class="small text-muted mb-0">Building modular planning engines, financial cash registries, and micro-tracking matrices for student councils.</p>
                    </div>
                </div>

                <div class="timeline-item" id="experience-item-2">
                    <div class="timeline-node"></div>
                    <div class="timeline-date">2024 - 2025</div>
                    <div class="timeline-content">
                        <h4 class="h6 mb-1 text-white">Software Engineering Student</h4>
                        <p class="small text-accent mb-2">Technical Academy</p>
                        <p class="small text-muted mb-0">Constructed high-speed ADO.NET and EF Core data layers, mastered standard C# programming, and established clean Bootstrap UI styling frameworks.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 3. TECHNICAL SKILLS MATRIX -->
<section id="skills-section" class="py-5 border-top border-secondary-subtle">
    <div class="mb-5">
        <span class="mono-tag">02. capability</span>
        <h2 class="h1 mt-2">Technical Skills Matrix</h2>
    </div>

    <div class="row g-4" id="skills-grid">
        @if (!skills.Any())
        {
            <div class="col-12 text-center text-muted">
                <p>No technical skills seeded. Please seed the database.</p>
            </div>
        }
        else
        {
            var categories = skills.Select(s => s.Category).Distinct();
            foreach (var cat in categories)
            {
                <div class="col-md-4">
                    <div class="glass-card h-100 glow-card">
                        <h3 class="h5 mb-4 text-accent text-uppercase border-bottom pb-2" style="letter-spacing: 0.05em;">@cat</h3>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var skill in skills.Where(s => s.Category == cat))
                            {
                                <div class="skill-badge" id="skill-badge-@skill.Id">
                                    @if (!string.IsNullOrEmpty(skill.IconClass))
                                    {
                                        <i class="@skill.IconClass text-accent"></i>
                                    }
                                    <span>@skill.Name</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</section>

<!-- 4. LEADERSHIP SECTION -->
<section id="leadership-section" class="py-5 border-top border-secondary-subtle">
    <div class="mb-5">
        <span class="mono-tag">03. community impact</span>
        <h2 class="h1 mt-2">Leadership Activities</h2>
    </div>

    <div class="row g-4" id="leadership-grid">
        <div class="col-md-6">
            <div class="glass-card h-100 glow-card" id="leadership-card-1">
                <div class="d-flex justify-content-between mb-3 align-items-start">
                    <h3 class="h5 mb-0 text-white">Event Coordinator</h3>
                    <span class="mono-tag">HACKATHON 2026</span>
                </div>
                <p class="small text-muted mb-0">
                    Chaired the operations council for a regional developer hackathon. Orchestrated team matrices of 15 members, supervised timeline Milestones, and coordinated cash allocations.
                </p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="glass-card h-100 glow-card" id="leadership-card-2">
                <div class="d-flex justify-content-between mb-3 align-items-start">
                    <h3 class="h5 mb-0 text-white">Developer Lead & Mentor</h3>
                    <span class="mono-tag">STUDENT ALLIANCE</span>
                </div>
                <p class="small text-muted mb-0">
                    Mentored junior students in learning relational database modeling and MVC backend controllers in .NET, advocating for clean software design patterns.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- 5. CONTACT FORM & CTA -->
<section id="contact-section" class="py-5 border-top border-secondary-subtle">
    <div class="row align-items-center">
        <div class="col-lg-5 mb-5 mb-lg-0">
            <span class="mono-tag">04. collaboration</span>
            <h2 class="display-5 mt-2 mb-4" style="font-family: var(--font-display); line-height: 1.2;">
                Let's construct something outstanding.
            </h2>
            <p class="text-muted">
                I am actively looking for full-stack programming opportunities, blogs contributions, and technical team mentoring roles. Send me an inquiry directly using the form, and I will get back to you shortly.
            </p>
            <div class="mt-4">
                <p class="mb-1"><i class="bi bi-envelope text-accent"></i> denzel.dev@gmail.com</p>
                <p class="mb-0"><i class="bi bi-geo-alt text-accent"></i> Windows Workspace LocalHost</p>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="glass-card glow-card">
                <form asp-controller="Home" asp-action="SubmitContact" method="post" id="contact-form">
                    @Html.AntiForgeryToken()
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label">Full Name *</label>
                            <input asp-for="Name" class="form-control minimalist-input" id="contact-name" placeholder="John Doe" required autocomplete="name">
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label">Email Address *</label>
                            <input asp-for="Email" type="email" class="form-control minimalist-input" id="contact-email" placeholder="john@example.com" required autocomplete="email">
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Subject" class="form-label">Subject *</label>
                        <input asp-for="Subject" class="form-control minimalist-input" id="contact-subject" placeholder="Collaboration opportunity..." required>
                        <span asp-validation-for="Subject" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Message" class="form-label">Inquiry Message *</label>
                        <textarea asp-for="Message" class="form-control minimalist-input" id="contact-message" rows="5" placeholder="Write message body here..." required></textarea>
                        <span asp-validation-for="Message" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn-premium-solid border-0" id="btn-contact-submit">Dispatch Message &rarr;</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

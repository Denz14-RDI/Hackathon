@model IEnumerable<DenzelDev.Models.Blog>
@{
    ViewData["Title"] = "Tech Blog";
}

<div class="py-4">
    <h1 class="mb-4">Technical Blog Articles</h1>

    <div class="row g-4" id="blogs-grid">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-center text-muted py-5">
                <p>No blog posts published yet. Stay tuned!</p>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                <div class="col-12">
                    <div class="card shadow-sm border h-100" id="blog-card-@item.Id">
                        <div class="row g-0">
                            @if (!string.IsNullOrEmpty(item.BannerImageUrl))
                            {
                                <div class="col-md-3">
                                    <img src="@item.BannerImageUrl" class="img-fluid rounded-start h-100" alt="@item.Title" style="object-fit: cover; min-height: 180px;">
                                </div>
                            }
                            <div class="col-md-@(string.IsNullOrEmpty(item.BannerImageUrl) ? "12" : "9")">
                                <div class="card-body d-flex flex-column h-100">
                                    <div class="mb-2 text-muted small d-flex gap-3">
                                        <span><i class="bi bi-calendar"></i> @item.PublishedDate.ToString("MMMM dd, yyyy")</span>
                                        <span><i class="bi bi-clock"></i> @item.ReadTimeMinutes Min Read</span>
                                    </div>
                                    <h3 class="card-title h5">
                                        <a href="/blogs/@item.Slug" class="text-decoration-none text-dark" id="btn-read-blog-@item.Id">@item.Title</a>
                                    </h3>
                                    
                                    <!-- Extract/Excerpt representation -->
                                    <p class="card-text text-muted flex-grow-1">
                                        @(item.ContentMarkdown.Length > 200 ? item.ContentMarkdown.Substring(0, 197) + "..." : item.ContentMarkdown)
                                    </p>

                                    <div class="mt-2">
                                        <a href="/blogs/@item.Slug" class="btn btn-sm btn-outline-dark" id="btn-read-more-@item.Id">Read Full Article &rarr;</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
